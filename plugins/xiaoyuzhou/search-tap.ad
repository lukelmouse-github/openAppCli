# @name 搜索播客(坐标版)
# @description 使用坐标点击搜索，适用于特定设备
# @app 小宇宙
# @package app.podcast.cosmos
# @device 5cbab8d9
# @params keyword

context platform=android
open app.podcast.cosmos
wait 2000

# 点击搜索入口 (x:50-952, y:195-244, 中心约 501,219)
tap 501 219
wait 800

# 输入搜索词
type {{keyword}}
wait 300

# 点击搜索
enter
wait 1500

snapshot
